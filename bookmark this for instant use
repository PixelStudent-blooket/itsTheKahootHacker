javascript:(async()=>{const i=prompt("Kahoot URL/ID:");const d=i?.match(/[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}/i)?.[0]||i;if(!d)return;try{const r=await fetch(`https://kahoot.it{d}/card/?includeKahoot=true`);const{kahoot:k}=await r.json();const m=Object.fromEntries(k.questions.map(q=>[q.question.replace(/<[^>]*>/g,'').trim().toLowerCase(),q.choices?.filter(c=>c.correct).map(c=>c.answer.replace(/<[^>]*>/g,'').trim().toLowerCase())]));setInterval(()=>{const q=document.querySelector('[data-functional-selector="question-block"]');const a=m[q?.innerText.trim().toLowerCase()];if(a)document.querySelectorAll('button[data-functional-selector^="answer-"]').forEach(b=>{if(a.includes(b.innerText.trim().toLowerCase()))b.click()})},75)}catch(e){alert("Private/Invalid ID")}})();
